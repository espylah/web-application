# PSRAM (OPI PSRAM on ESP32-S3-WROOM-1-N8R8)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
# Inference monopolizes CPU0 for several seconds — exclude idle task from WDT
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=n

CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768

# FAT Long File Name support (required for model filenames > 8 chars)
CONFIG_FATFS_LFN_HEAP=y

# Custom partition table (3.5MB OTA partitions for ESP-DL binary size)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000


# BLE (Bluedroid + GATT server — required by ble_config component)
CONFIG_BT_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
CONFIG_BT_CONTROLLER_ENABLED=y
CONFIG_BT_BLE_ENABLED=y
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y
CONFIG_BT_GATTS_ENABLE=y

# Default to 8MB Flash
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y

#Do not skip provisioning in prod.
CONFIG_SKIP_PROVISIONING=n

CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y


CONFIG_CNN_MODEL_PARTITION=y